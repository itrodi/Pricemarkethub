{
  "name": "pricewise-scraper",
  "version": "1.0.0",
  "description": "Price data scraper for PriceWise Nigeria - Jumia, Konga, Jiji",
  "type": "module",
  "scripts": {
    "scrape": "node src/index.js",
    "scrape:jumia": "node src/index.js --source jumia",
    "scrape:konga": "node src/index.js --source konga",
    "scrape:jiji": "node src/index.js --source jiji",
    "schedule": "node src/scheduler.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.98.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.5.0"
  }
}
