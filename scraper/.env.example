# PostgreSQL Connection
DATABASE_URL=postgresql://pricewise:your-password@localhost:5432/pricewise

# Scraper Settings
SCRAPE_DELAY_MIN=1500
SCRAPE_DELAY_MAX=4000
MAX_PAGES_PER_CATEGORY=50

# Proxy (optional - for residential proxy rotation)
# PROXY_URL=http://user:pass@proxy.example.com:8080
# Or set HTTP_PROXY/HTTPS_PROXY environment variables

# Logging
LOG_LEVEL=info

# Schedule (hours in 24h format, comma-separated)
SCHEDULE_HOURS=3,15
SCHEDULE_INTERVAL=60

# Scraper API Server
SCRAPER_PORT=3001
