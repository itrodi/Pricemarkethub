# Supabase Configuration
# Get these from your Supabase project dashboard: https://supabase.com/dashboard
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# The app works without these — it will use built-in mock data.
# Connect to Supabase for production use with real data.
#
# Admin Dashboard:
#   Without Supabase: use demo credentials (admin@pricewise.ng / pricewise2025)
#   With Supabase: create a user in Supabase Auth and sign in with those credentials
#
# Scraper:
#   See scraper/.env.example for scraper-specific configuration
